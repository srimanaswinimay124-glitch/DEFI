<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>SentinelDeFi — DeFiPulse</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    :root {
      --bg:        #0d1117;
      --surface:   #161b22;
      --surface2:  #1c2333;
      --border:    #21262d;
      --teal:      #2dd4bf;
      --teal-dim:  rgba(45,212,191,.15);
      --teal-glow: 0 0 20px rgba(45,212,191,.2);
      --text:      #e6edf3;
      --muted:     #7d8590;
      --red:       #f85149;
      --orange:    #d29922;
      --green:     #3fb950;
      --purple:    #a371f7;
      --r:         10px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--bg); color: var(--text); font-family: 'Sora', sans-serif; font-size: 14px; min-height: 100vh; }

    /* ── NAV ── */
    nav {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 32px; height: 60px;
      background: var(--surface); border-bottom: 1px solid var(--border);
      position: sticky; top: 0; z-index: 100;
    }
    .nav-logo { display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 16px; color: var(--text); text-decoration: none; }
    .logo-icon {
      width: 32px; height: 32px; border-radius: 8px;
      background: var(--teal); display: grid; place-items: center;
    }
    .logo-icon svg { width: 18px; height: 18px; color: #0d1117; }
    .nav-links { display: flex; gap: 4px; }
    .nav-link {
      display: flex; align-items: center; gap: 7px;
      padding: 7px 16px; border-radius: 8px; font-size: 14px; font-weight: 500;
      color: var(--muted); text-decoration: none; border: none; background: none; cursor: pointer;
      transition: color .15s, background .15s;
    }
    .nav-link:hover { color: var(--text); background: var(--surface2); }
    .nav-link.active { background: var(--teal); color: #0d1117; }
    .nav-link svg { width: 15px; height: 15px; flex-shrink: 0; }
    .live-badge { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--green); }
    .live-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--green); animation: blink 1.8s infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

    /* ── PAGES ── */
    .page { display: none; padding: 32px; max-width: 1280px; margin: 0 auto; }
    .page.active { display: block; }

    /* ── PAGE HEADER ── */
    .page-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 28px; }
    .page-header h1 { font-size: 26px; font-weight: 700; color: var(--text); }
    .page-header p  { color: var(--muted); margin-top: 4px; font-size: 14px; }

    /* ── BTN ── */
    .btn {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 9px 18px; border-radius: 8px; font-size: 14px; font-weight: 600;
      cursor: pointer; border: none; transition: all .15s; font-family: 'Sora', sans-serif;
    }
    .btn-teal  { background: var(--teal); color: #0d1117; }
    .btn-teal:hover { filter: brightness(1.1); box-shadow: var(--teal-glow); }
    .btn-ghost { background: transparent; color: var(--muted); border: 1px solid var(--border); }
    .btn-ghost:hover { color: var(--text); border-color: var(--muted); }
    .btn svg { width: 15px; height: 15px; }

    /* ── CARD ── */
    .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r); padding: 20px; }

    /* ── METRIC CARDS ── */
    .metrics-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 20px; }
    .metric-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r); padding: 20px 22px; }
    .metric-top  { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
    .metric-label { font-size: 11px; font-weight: 600; letter-spacing: .08em; color: var(--muted); text-transform: uppercase; }
    .metric-icon  { width: 34px; height: 34px; border-radius: 8px; display: grid; place-items: center; }
    .metric-icon.teal   { background: var(--teal-dim); color: var(--teal); }
    .metric-icon.purple { background: rgba(163,113,247,.12); color: var(--purple); }
    .metric-icon.red    { background: rgba(248,81,73,.1); color: var(--red); }
    .metric-icon.blue   { background: rgba(88,166,255,.1); color: #58a6ff; }
    .metric-icon svg    { width: 17px; height: 17px; }
    .metric-value { font-size: 30px; font-weight: 700; color: var(--text); margin-bottom: 6px; }
    .metric-sub   { font-size: 12px; color: var(--green); display: flex; align-items: center; gap: 4px; }
    .metric-sub svg { width: 12px; height: 12px; }

    /* ── DASHBOARD CHARTS ROW ── */
    .charts-row { display: grid; grid-template-columns: 1fr 320px; gap: 16px; margin-bottom: 20px; }
    .chart-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r); padding: 20px; }
    .chart-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
    .chart-title  { font-size: 15px; font-weight: 600; }
    .badge-green  { background: rgba(63,185,80,.15); color: var(--green); padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    canvas { max-height: 220px; }

    /* ── EMPTY STATE ── */
    .empty-state {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 60px 20px; color: var(--muted); gap: 10px; text-align: center;
    }
    .empty-state svg { width: 40px; height: 40px; opacity: .4; }
    .empty-state p { font-size: 14px; }

    /* ── INSIGHTS STRIP ── */
    .insights-strip { margin-top: 20px; }
    .strip-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
    .strip-header span { font-size: 15px; font-weight: 600; }
    .strip-count  { font-size: 13px; color: var(--muted); }
    .insights-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
    .insight-mini { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r); padding: 16px; }
    .insight-mini-top { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
    .insight-title { font-size: 13px; font-weight: 600; }
    .sev-badge { padding: 2px 9px; border-radius: 20px; font-size: 11px; font-weight: 600; }
    .sev-high   { background: rgba(248,81,73,.15);   color: var(--red);    }
    .sev-medium { background: rgba(210,153,34,.15);  color: var(--orange); }
    .sev-low    { background: rgba(63,185,80,.15);   color: var(--green);  }
    .token-tags { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 10px; }
    .token-tag  { background: var(--surface2); border: 1px solid var(--border); border-radius: 4px; padding: 2px 8px; font-size: 11px; color: var(--muted); }

    /* ── PORTFOLIO SUMMARY BAR ── */
    .summary-bar { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r); padding: 18px 24px; margin-bottom: 20px; display: flex; gap: 40px; }
    .sum-item label { font-size: 11px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); display: block; margin-bottom: 4px; }
    .sum-item span  { font-size: 22px; font-weight: 700; color: var(--text); }

    /* ── TABLE ── */
    .table-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r); overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    th { padding: 12px 18px; text-align: left; font-size: 11px; font-weight: 600; letter-spacing: .07em; text-transform: uppercase; color: var(--muted); border-bottom: 1px solid var(--border); }
    td { padding: 14px 18px; font-size: 14px; border-bottom: 1px solid var(--border); }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: var(--surface2); }
    .pos-pnl.pos { color: var(--green); }
    .pos-pnl.neg { color: var(--red); }
    .chain-pill { background: var(--surface2); border: 1px solid var(--border); border-radius: 20px; padding: 3px 10px; font-size: 12px; color: var(--muted); }
    .del-btn { background: none; border: none; cursor: pointer; color: var(--muted); padding: 4px 8px; border-radius: 4px; }
    .del-btn:hover { color: var(--red); background: rgba(248,81,73,.1); }

    /* ── ALERTS ── */
    .alerts-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 20px; }
    .alert-stat { border-radius: var(--r); padding: 24px; text-align: center; }
    .alert-stat.triggered { background: rgba(210,153,34,.08); border: 1px solid rgba(210,153,34,.25); }
    .alert-stat.active    { background: rgba(63,185,80,.08);  border: 1px solid rgba(63,185,80,.25); }
    .alert-stat.paused    { background: var(--surface);       border: 1px solid var(--border); }
    .alert-stat-num { font-size: 34px; font-weight: 700; }
    .alert-stat.triggered .alert-stat-num { color: var(--orange); }
    .alert-stat.active    .alert-stat-num { color: var(--green); }
    .alert-stat.paused    .alert-stat-num { color: var(--muted); }
    .alert-stat-label { font-size: 13px; color: var(--muted); margin-top: 4px; }

    /* ── AI INSIGHTS PAGE ── */
    .filter-bar { display: flex; gap: 8px; margin-bottom: 20px; }
    .filter-btn {
      padding: 6px 16px; border-radius: 20px; font-size: 13px; font-weight: 500;
      cursor: pointer; border: 1px solid var(--border); background: var(--surface);
      color: var(--muted); font-family: 'Sora', sans-serif; transition: all .15s;
    }
    .filter-btn.active { background: var(--teal); color: #0d1117; border-color: var(--teal); }
    .filter-btn:hover:not(.active) { color: var(--text); border-color: var(--muted); }
    .insight-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r); padding: 20px; margin-bottom: 12px; }
    .insight-card-top { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
    .insight-icon { width: 36px; height: 36px; border-radius: 8px; display: grid; place-items: center; flex-shrink: 0; }
    .insight-icon.risk        { background: rgba(248,81,73,.1);   color: var(--red); }
    .insight-icon.opportunity { background: rgba(63,185,80,.1);  color: var(--green); }
    .insight-icon.market      { background: rgba(88,166,255,.1); color: #58a6ff; }
    .insight-icon.alert       { background: rgba(210,153,34,.1); color: var(--orange); }
    .insight-icon svg { width: 17px; height: 17px; }
    .insight-body { font-size: 13px; color: var(--muted); line-height: 1.6; margin-bottom: 12px; }

    /* ── MODAL ── */
    .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.6); z-index: 200; place-items: center; }
    .overlay.open { display: grid; }
    .modal { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 28px; width: 440px; max-width: 95vw; }
    .modal h2 { font-size: 18px; font-weight: 700; margin-bottom: 20px; }
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 12px; font-weight: 600; color: var(--muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: .06em; }
    .form-group input, .form-group select {
      width: 100%; padding: 9px 12px; background: var(--bg); border: 1px solid var(--border);
      border-radius: 7px; color: var(--text); font-family: 'Sora', sans-serif; font-size: 14px;
      outline: none; transition: border-color .15s;
    }
    .form-group input:focus, .form-group select:focus { border-color: var(--teal); }
    .form-group select option { background: var(--surface); }
    .modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 22px; }

    /* ── CHAIN DIST ── */
    #chainChart { max-height: 180px; }
    .no-pos-chain { display: flex; align-items: center; justify-content: center; height: 180px; color: var(--muted); font-size: 13px; }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
