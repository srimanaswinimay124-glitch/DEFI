<!-- ═══════════════ AI INSIGHTS ═══════════════ -->
<div id="page-ai-insights" class="page">
  <div class="page-header">
    <div>
      <h1>AI Insights</h1>
      <p>Intelligent analysis powered by AI</p>
    </div>
    <div style="display:flex;gap:10px;">
      <button class="btn btn-ghost" onclick="markAllRead()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        Mark all read (<span id="ai-unread">3</span>)
      </button>
      <button class="btn btn-teal" onclick="generateInsight()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
        Generate Insights
      </button>
    </div>
  </div>

  <div class="filter-bar">
    <button class="filter-btn active" data-filter="all"         onclick="filterInsights('all',this)">All</button>
    <button class="filter-btn"        data-filter="risk"        onclick="filterInsights('risk',this)">Risk <span id="fc-risk"></span></button>
    <button class="filter-btn"        data-filter="opportunity" onclick="filterInsights('opportunity',this)">Opportunity <span id="fc-opp"></span></button>
    <button class="filter-btn"        data-filter="alert"       onclick="filterInsights('alert',this)">Alert <span id="fc-alert"></span></button>
    <button class="filter-btn"        data-filter="market"      onclick="filterInsights('market',this)">Market <span id="fc-market"></span></button>
  </div>

  <div id="ai-list"></div>
</div>

<!-- ═══════════════ MODALS ═══════════════ -->

<!-- Add Position Modal -->
<div class="overlay" id="posModal">
  <div class="modal">
    <h2>Add Position</h2>
    <div class="form-group"><label>Protocol</label><input id="pm-protocol" placeholder="e.g. Uniswap"/></div>
    <div class="form-group"><label>Chain</label>
      <select id="pm-chain">
        <option>Ethereum</option><option>Polygon</option><option>Arbitrum</option><option>Optimism</option><option>Base</option>
      </select>
    </div>
    <div class="form-group"><label>Asset</label><input id="pm-asset" placeholder="e.g. ETH/USDC LP"/></div>
    <div class="form-group"><label>Amount</label><input id="pm-amount" type="number" placeholder="0.00"/></div>
    <div class="form-group"><label>Value (USD)</label><input id="pm-value" type="number" placeholder="0.00"/></div>
    <div class="form-group"><label>P&L (USD)</label><input id="pm-pnl" type="number" placeholder="0.00"/></div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeModal('posModal')">Cancel</button>
      <button class="btn btn-teal" onclick="addPosition()">Add Position</button>
    </div>
  </div>
</div>

<!-- New Alert Modal -->
<div class="overlay" id="alertModal">
  <div class="modal">
    <h2>New Alert</h2>
    <div class="form-group"><label>Alert Name</label><input id="am-name" placeholder="e.g. ETH Price Alert"/></div>
    <div class="form-group"><label>Asset</label><input id="am-asset" placeholder="e.g. ETH"/></div>
    <div class="form-group"><label>Condition</label>
      <select id="am-cond"><option value="above">Price goes above</option><option value="below">Price goes below</option><option value="liquidity">Liquidity drops below</option></select>
    </div>
    <div class="form-group"><label>Threshold (USD)</label><input id="am-threshold" type="number" placeholder="0.00"/></div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeModal('alertModal')">Cancel</button>
      <button class="btn btn-teal" onclick="addAlert()">Create Alert</button>
    </div>
  </div>
</div>

<script>
// ── Page routing ──────────────────────────────────────────────────────────────
let currentPage = 'dashboard';

function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-link').forEach(l => l.classList.toggle('active', l.dataset.page === name));
  document.getElementById('page-' + name).classList.add('active');
  currentPage = name;
  if (name === 'dashboard')    loadDashboard();
  if (name === 'portfolio')    loadPortfolio();
  if (name === 'alerts')       loadAlerts();
  if (name === 'ai-insights')  loadInsights('all');
}

// ── Modal ─────────────────────────────────────────────────────────────────────
function openModal(id)  { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.overlay').forEach(o => o.addEventListener('click', e => { if (e.target === o) o.classList.remove('open'); }));

// ── Dashboard ─────────────────────────────────────────────────────────────────
let chartInstance = null;

async function loadDashboard() {
  const d = await fetch('/api/dashboard').then(r => r.json());
  document.getElementById('d-val').textContent     = '$' + d.portfolio_value.toLocaleString();
  document.getElementById('d-pnl').textContent     = (d.total_pnl >= 0 ? '+$' : '-$') + Math.abs(d.total_pnl).toLocaleString();
  document.getElementById('d-alerts').textContent  = d.active_alerts;
  document.getElementById('d-pos').textContent     = d.positions_count;
  document.getElementById('d-pnl-pct').textContent = (d.pnl_pct >= 0 ? '+' : '') + d.pnl_pct + '% all time';
  document.getElementById('d-trig').textContent    = '+' + d.triggered_pct + '% triggered';

  // Chart
  const labels = d.chart.map(p => p.t);
  const vals   = d.chart.map(p => p.v);
  const ctx = document.getElementById('portfolioChart').getContext('2d');
  if (chartInstance) chartInstance.destroy();
  const grad = ctx.createLinearGradient(0, 0, 0, 220);
  grad.addColorStop(0,   'rgba(45,212,191,.25)');
  grad.addColorStop(1,   'rgba(45,212,191,0)');
  chartInstance = new Chart(ctx, {
    type: 'line',
    data: { labels, datasets: [{ data: vals, borderColor: '#2dd4bf', backgroundColor: grad, borderWidth: 2, pointRadius: 0, fill: true, tension: 0.4 }] },
    options: {
      responsive: true, plugins: { legend: { display: false } },
      scales: {
        x: { grid: { color: 'rgba(255,255,255,.05)' }, ticks: { color: '#7d8590', font: { size: 11 }, maxTicksLimit: 7 } },
        y: { grid: { color: 'rgba(255,255,255,.05)' }, ticks: { color: '#7d8590', font: { size: 11 }, callback: v => '$' + (v/1000).toFixed(0) + 'k' } }
      }
    }
  });

  // Chain dist
  const wrap = document.getElementById('chainDistWrap');
  if (!d.chain_dist.length) {
    wrap.innerHTML = '<div class="no-pos-chain">No positions yet</div>';
  } else {
    wrap.innerHTML = '<canvas id="chainChart"></canvas>';
    const colors = ['#2dd4bf','#a371f7','#58a6ff','#3fb950','#f0883e'];
    new Chart(document.getElementById('chainChart').getContext('2d'), {
      type: 'doughnut',
      data: { labels: d.chain_dist.map(c => c.chain), datasets: [{ data: d.chain_dist.map(c => c.value), backgroundColor: colors, borderWidth: 0 }] },
      options: { plugins: { legend: { position: 'bottom', labels: { color: '#7d8590', font: { size: 12 }, padding: 12 } } }, cutout: '65%' }
    });
  }

  // Insights strip
  const row = document.getElementById('d-insights-row');
  row.innerHTML = d.recent_insights.map(i => insightMiniHTML(i)).join('');
  document.getElementById('d-insight-count').textContent = d.recent_insights.length + ' insights';
}

function insightMiniHTML(i) {
  const icons = { risk: riskIcon(), opportunity: growIcon(), market: barIcon(), alert: bellIcon() };
  return `<div class="insight-mini">
    <div class="insight-mini-top">
      <div class="insight-icon ${i.type}">${icons[i.type] || riskIcon()}</div>
      <span class="insight-title">${i.title}</span>
      <span class="sev-badge sev-${i.severity}">${i.severity}</span>
    </div>
    <div class="token-tags">
      ${i.tokens.map(t => `<span class="token-tag">${t}</span>`).join('')}
      ${i.protocols.map(p => `<span class="token-tag">${p}</span>`).join('')}
    </div>
  </div>`;
}

// ── Portfolio ─────────────────────────────────────────────────────────────────
async function loadPortfolio() {
  const d = await fetch('/api/portfolio').then(r => r.json());
  document.getElementById('p-val').textContent   = '$' + d.total_value.toLocaleString();
  document.getElementById('p-pos').textContent   = d.positions;
  document.getElementById('p-proto').textContent = d.protocols;
  const wrap = document.getElementById('p-table-wrap');
  if (!d.items.length) {
    wrap.innerHTML = `<div class="empty-state">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
      <p>No positions yet. Add your first DeFi position.</p></div>`;
    return;
  }
  wrap.innerHTML = `<table>
    <thead><tr><th>Protocol</th><th>Chain</th><th>Asset</th><th>Amount</th><th>Value</th><th>P&L</th><th></th></tr></thead>
    <tbody>${d.items.map(p => `<tr>
      <td>${p.protocol}</td>
      <td><span class="chain-pill">${p.chain}</span></td>
      <td>${p.asset}</td>
      <td>${p.amount}</td>
      <td>$${p.value.toLocaleString()}</td>
      <td class="pos-pnl ${p.pnl >= 0 ? 'pos' : 'neg'}">${p.pnl >= 0 ? '+' : ''}$${p.pnl.toLocaleString()}</td>
      <td><button class="del-btn" onclick="deletePosition(${p.id})">✕</button></td>
    </tr>`).join('')}</tbody>
  </table>`;
}

async function addPosition() {
  await fetch('/api/portfolio', { method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      protocol: document.getElementById('pm-protocol').value,
      chain:    document.getElementById('pm-chain').value,
      asset:    document.getElementById('pm-asset').value,
      amount:   document.getElementById('pm-amount').value,
      value:    document.getElementById('pm-value').value,
      pnl:      document.getElementById('pm-pnl').value,
    })
  });
  closeModal('posModal');
  ['pm-protocol','pm-asset','pm-amount','pm-value','pm-pnl'].forEach(id => document.getElementById(id).value = '');
  loadPortfolio();
}

async function deletePosition(id) {
  await fetch('/api/portfolio/' + id, { method: 'DELETE' });
  loadPortfolio();
}

// ── Alerts ────────────────────────────────────────────────────────────────────
async function loadAlerts() {
  const d = await fetch('/api/alerts').then(r => r.json());
  document.getElementById('a-triggered').textContent = d.triggered;
  document.getElementById('a-active').textContent    = d.active;
  document.getElementById('a-paused').textContent    = d.paused;
  const wrap = document.getElementById('a-table-wrap');
  if (!d.items.length) {
    wrap.innerHTML = `<div class="empty-state">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
      <p>No alerts set. Create your first price or liquidity alert.</p></div>`;
    return;
  }
  wrap.innerHTML = `<table>
    <thead><tr><th>Name</th><th>Asset</th><th>Condition</th><th>Threshold</th><th>Status</th><th>Created</th><th></th></tr></thead>
    <tbody>${d.items.map(a => `<tr>
      <td>${a.name}</td><td>${a.asset}</td><td>${a.condition}</td>
      <td>$${a.threshold.toLocaleString()}</td>
      <td><span class="sev-badge ${a.status === 'active' ? 'sev-low' : a.status === 'triggered' ? 'sev-high' : 'sev-medium'}">${a.status}</span></td>
      <td style="color:var(--muted)">${a.created_at}</td>
      <td><button class="del-btn" onclick="deleteAlert(${a.id})">✕</button></td>
    </tr>`).join('')}</tbody>
  </table>`;
}

async function addAlert() {
  await fetch('/api/alerts', { method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      name:      document.getElementById('am-name').value,
      asset:     document.getElementById('am-asset').value,
      condition: document.getElementById('am-cond').value,
      threshold: document.getElementById('am-threshold').value,
    })
  });
  closeModal('alertModal');
  ['am-name','am-asset','am-threshold'].forEach(id => document.getElementById(id).value = '');
  loadAlerts();
}

async function deleteAlert(id) {
  await fetch('/api/alerts/' + id, { method: 'DELETE' });
  loadAlerts();
}

// ── AI Insights ───────────────────────────────────────────────────────────────
let currentFilter = 'all';

async function loadInsights(filter) {
  const d = await fetch('/api/insights?type=' + filter).then(r => r.json());
  document.getElementById('ai-unread').textContent = d.unread;
  const icons = { risk: riskIcon(), opportunity: growIcon(), market: barIcon(), alert: bellIcon() };

  // filter counts
  const all = await fetch('/api/insights?type=all').then(r => r.json());
  const counts = {};
  all.items.forEach(i => counts[i.type] = (counts[i.type] || 0) + 1);
  document.getElementById('fc-risk').textContent   = '(' + (counts.risk || 0) + ')';
  document.getElementById('fc-opp').textContent    = '(' + (counts.opportunity || 0) + ')';
  document.getElementById('fc-alert').textContent  = '(' + (counts.alert || 0) + ')';
  document.getElementById('fc-market').textContent = '(' + (counts.market || 0) + ')';

  document.getElementById('ai-list').innerHTML = d.items.map(i => `
    <div class="insight-card">
      <div class="insight-card-top">
        <div class="insight-icon ${i.type}">${icons[i.type] || riskIcon()}</div>
        <span class="insight-title" style="font-size:15px">${i.title}</span>
        <span class="sev-badge sev-${i.severity}">${i.severity}</span>
        ${!i.read ? '<span style="width:7px;height:7px;background:var(--teal);border-radius:50%;display:inline-block;margin-left:auto"></span>' : ''}
      </div>
      <p class="insight-body">${i.body}</p>
      <div class="token-tags">
        ${i.tokens.map(t => `<span class="token-tag">${t}</span>`).join('')}
        ${i.protocols.map(p => `<span class="token-tag">${p}</span>`).join('')}
      </div>
    </div>
  `).join('') || '<div class="empty-state"><p>No insights for this category.</p></div>';
}

function filterInsights(type, btn) {
  currentFilter = type;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.toggle('active', b === btn));
  loadInsights(type);
}

async function generateInsight() {
  await fetch('/api/insights/generate', { method: 'POST' });
  loadInsights(currentFilter);
}

async function markAllRead() {
  await fetch('/api/insights/read-all', { method: 'POST' });
  loadInsights(currentFilter);
}

// ── SVG icons ─────────────────────────────────────────────────────────────────
function riskIcon()  { return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`; }
function growIcon()  { return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`; }
function barIcon()   { return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`; }
function bellIcon()  { return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>`; }

// ── Init ──────────────────────────────────────────────────────────────────────
const initPage = '{{ page }}';
showPage(initPage);
</script>
</body>
</html>
